---
import { useTranslations } from '../i18n/utils';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const locale = Astro.currentLocale || 'es';
const { t } = useTranslations(locale);
const siteTitle = title ?? t('site.title');
const siteDesc = description ?? t('site.description');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDesc} />
    <meta name="keywords" content="dibujo, clases online, bellas artes, niños, adolescentes, arte digital" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <title>{siteTitle}</title>
  </head>
  <body class="bg-paper text-ink font-body antialiased">
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-paper/80 border-b border-complementary-200/50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <a href={locale === 'es' ? '/' : `/${locale}/`} class="text-xl font-display font-bold text-brand-700 hover:text-brand-600 transition-colors">
            ✦ {t('site.title')}
          </a>

          <div class="hidden md:flex items-center gap-8">
            <a href={locale === 'es' ? '/' : `/${locale}/`} class="text-sm font-medium text-ink-light hover:text-ink transition-colors">
              {t('nav.inicio')}
            </a>
            <a href={locale === 'es' ? '/clases' : `/${locale}/clases`} class="text-sm font-medium text-ink-light hover:text-ink transition-colors">
              {t('nav.clases')}
            </a>
            <a href={locale === 'es' ? '/galeria' : `/${locale}/galeria`} class="text-sm font-medium text-ink-light hover:text-ink transition-colors">
              {t('nav.galeria')}
            </a>
            <a href={locale === 'es' ? '/blog' : `/${locale}/blog`} class="text-sm font-medium text-ink-light hover:text-ink transition-colors">
              {t('nav.blog')}
            </a>
            <a href={locale === 'es' ? '/contacto' : `/${locale}/contacto`} class="text-sm font-medium text-ink-light hover:text-ink transition-colors">
              {t('nav.contacto')}
            </a>

            <!-- Language Selector -->
            <div class="flex items-center gap-1 border-l border-complementary-200 pl-4">
              <a href="/" class={`px-2 py-1 text-xs rounded transition-colors ${locale === 'es' ? 'bg-brand-600 text-white' : 'text-ink-light hover:text-ink'}`}>
                ES
              </a>
              <a href="/en/" class={`px-2 py-1 text-xs rounded transition-colors ${locale === 'en' ? 'bg-brand-600 text-white' : 'text-ink-light hover:text-ink'}`}>
                EN
              </a>
              <a href="/uk/" class={`px-2 py-1 text-xs rounded transition-colors ${locale === 'uk' ? 'bg-brand-600 text-white' : 'text-ink-light hover:text-ink'}`}>
                UK
              </a>
            </div>
          </div>

          <!-- Mobile menu button -->
          <button id="menu-toggle" class="md:hidden p-2 text-ink" aria-label="Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </nav>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="md:hidden hidden bg-paper border-t border-complementary-200/50 px-4 py-4 space-y-3">
          <a href={locale === 'es' ? '/' : `/${locale}/`} class="block text-sm font-medium">{t('nav.inicio')}</a>
          <a href={locale === 'es' ? '/clases' : `/${locale}/clases`} class="block text-sm font-medium">{t('nav.clases')}</a>
          <a href={locale === 'es' ? '/galeria' : `/${locale}/galeria`} class="block text-sm font-medium">{t('nav.galeria')}</a>
          <a href={locale === 'es' ? '/blog' : `/${locale}/blog`} class="block text-sm font-medium">{t('nav.blog')}</a>
          <a href={locale === 'es' ? '/contacto' : `/${locale}/contacto`} class="block text-sm font-medium">{t('nav.contacto')}</a>
          <div class="flex gap-2 pt-2 border-t border-complementary-200/50">
            <a href="/" class="px-2 py-1 text-xs rounded bg-brand-600 text-white">ES</a>
            <a href="/en/" class="px-2 py-1 text-xs rounded text-ink-light">EN</a>
            <a href="/uk/" class="px-2 py-1 text-xs rounded text-ink-light">UK</a>
          </div>
        </div>
      </header>

      <!-- Main content -->
      <main class="flex-1 pt-16">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="bg-ink-dark text-paper-light py-12 px-4">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
              <h3 class="font-display text-lg font-semibold text-white mb-3">✦ {t('site.title')}</h3>
              <p class="text-sm text-paper/60">{t('site.description')}</p>
            </div>
            <div>
              <h4 class="font-medium text-white mb-3">{t('nav.clases')}</h4>
              <ul class="space-y-2 text-sm text-paper/60">
                <li>{t('servicios.individual.title')}</li>
                <li>{t('servicios.mentoria.title')}</li>
              </ul>
            </div>
            <div>
              <h4 class="font-medium text-white mb-3">{t('contacto.title')}</h4>
              <ul class="space-y-2 text-sm text-paper/60">
                <li>{t('contacto.info.email')}</li>
                <li>{t('contacto.info.whatsapp')}</li>
                <li>{t('contacto.info.horarios')}</li>
              </ul>
            </div>
          </div>
          <div class="mt-8 pt-8 border-t border-white/10 text-center text-sm text-paper/40">
            <p>© {new Date().getFullYear()} — {t('footer.derechos')}</p>
            <p class="mt-1">{t('footer.idiomas_disponibles')}</p>
          </div>
        </div>
      </footer>
    </div>

    <!-- Mobile menu toggle script -->
    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
      }
    </script>
  </body>
</html>
