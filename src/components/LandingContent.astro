---
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale || 'es';
const { t } = useTranslations(locale);
const localePrefix = locale === 'es' ? '' : `/${locale}`;
---

<!-- ════════════════════════════════════════════════════════ -->
<!-- HERO SECTION                                           -->
<!-- ════════════════════════════════════════════════════════ -->
<section id="hero" class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-b from-complementary-50 via-paper to-paper">
  <!-- Background decorative shapes (floating) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div data-float class="absolute top-20 left-[10%] w-48 h-48 rounded-full bg-complementary-200/20 blur-3xl"></div>
    <div data-float class="absolute top-40 right-[15%] w-64 h-64 rounded-full bg-complementary-300/15 blur-3xl"></div>
    <div data-float class="absolute bottom-20 left-[30%] w-36 h-36 rounded-full bg-accent-100/25 blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text content -->
      <div class="space-y-6">
        <span data-hero-badge class="inline-block px-4 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-full uppercase tracking-wider">
          Online · En vivo
        </span>

        <h1 data-hero-title class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-ink-dark leading-tight whitespace-pre-line">
          {t('hero.title')}
        </h1>

        <p data-hero-subtitle class="text-lg sm:text-xl text-ink-light leading-relaxed max-w-lg">
          {t('hero.subtitle')}
        </p>

        <div data-hero-cta class="flex flex-wrap gap-4 pt-2">
          <a
            href={localePrefix === '' ? '/contacto' : `${localePrefix}/contacto`}
            class="inline-flex items-center px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700 transition-all duration-300 shadow-lg shadow-brand-600/25 hover:shadow-brand-600/40 hover:-translate-y-0.5"
          >
            {t('hero.cta')}
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={localePrefix === '' ? '/galeria' : `${localePrefix}/galeria`}
            class="inline-flex items-center px-6 py-3 border-2 border-complementary-300 text-ink font-medium rounded-lg hover:border-complementary-500 hover:bg-complementary-50 transition-all duration-300"
          >
            {t('hero.cta_secondary')}
          </a>
        </div>
      </div>

      <!-- Hero image / decorative artwork -->
      <div data-hero-image class="relative">
        <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-complementary-100 to-complementary-200 shadow-2xl">
          <div class="absolute inset-0 flex items-center justify-center">
            <svg viewBox="0 0 400 300" class="w-full h-full text-complementary-300/60">
              <!-- Abstract art placeholder — SVG ilustrativo -->
              <circle cx="120" cy="100" r="60" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="120" cy="100" r="40" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6" />
              <circle cx="120" cy="100" r="20" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4" />
              <path d="M200 180 Q 250 100 300 180" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M220 160 Q 250 90 280 160" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6" />
              <line x1="50" y1="220" x2="350" y2="220" stroke="currentColor" stroke-width="1" stroke-dasharray="4 4" opacity="0.3" />
              <!-- Palette marks -->
              <circle cx="280" cy="80" r="8" fill="currentColor" opacity="0.4" />
              <circle cx="300" cy="60" r="5" fill="currentColor" opacity="0.3" />
              <circle cx="260" cy="60" r="6" fill="currentColor" opacity="0.35" />
              <!-- Frame -->
              <rect x="30" y="30" width="340" height="240" fill="none" stroke="currentColor" stroke-width="1.5" rx="8" opacity="0.2" />
            </svg>
          </div>
        </div>

        <!-- Decorative corner accent -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-r-2 border-b-2 border-accent-400 rounded-br-xl -z-10"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 border-l-2 border-t-2 border-accent-400 rounded-tl-xl -z-10"></div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-brand-400/60">
    <span class="text-xs uppercase tracking-widest font-medium">Scroll</span>
    <div class="w-0.5 h-8 bg-gradient-to-b from-brand-400/60 to-transparent"></div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════ -->
<!-- SERVICIOS / MODALIDADES SECTION                        -->
<!-- ════════════════════════════════════════════════════════ -->
<section class="py-24 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-brand-600 text-sm font-medium uppercase tracking-widest">
        {t('servicios.title')}
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink-dark mt-3">
        {t('servicios.subtitle')}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Individual -->
      <article class="group relative bg-paper rounded-2xl p-8 border border-complementary-100/50 hover:border-complementary-300/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-xl">
        <div class="w-12 h-12 rounded-xl bg-complementary-100 flex items-center justify-center mb-6 text-complementary-700 text-xl">
          ✏️
        </div>
        <h3 class="font-display text-xl font-semibold text-ink-dark mb-3">
          {t('servicios.individual.title')}
        </h3>
        <p class="text-ink-light leading-relaxed">
          {t('servicios.individual.desc')}
        </p>
      </article>

      <!-- Mentoría -->
      <article class="group relative bg-paper rounded-2xl p-8 border border-complementary-100/50 hover:border-complementary-300/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-xl">
        <div class="w-12 h-12 rounded-xl bg-complementary-100 flex items-center justify-center mb-6 text-complementary-700 text-xl">
          🎯
        </div>
        <h3 class="font-display text-xl font-semibold text-ink-dark mb-3">
          {t('servicios.mentoria.title')}
        </h3>
        <p class="text-ink-light leading-relaxed">
          {t('servicios.mentoria.desc')}
        </p>
      </article>

      <!-- Idiomas -->
      <article class="group relative bg-paper rounded-2xl p-8 border border-complementary-100/50 hover:border-complementary-300/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-xl">
        <div class="w-12 h-12 rounded-xl bg-complementary-100 flex items-center justify-center mb-6 text-complementary-700 text-xl">
          🌍
        </div>
        <h3 class="font-display text-xl font-semibold text-ink-dark mb-3">
          {t('servicios.idiomas.title')}
        </h3>
        <p class="text-ink-light leading-relaxed">
          {t('servicios.idiomas.desc')}
        </p>
      </article>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════ -->
<!-- GALERÍA PREVIEW SECTION                                -->
<!-- ════════════════════════════════════════════════════════ -->
<section class="py-24 px-4 bg-paper">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-brand-600 text-sm font-medium uppercase tracking-widest">
        {t('galeria.title')}
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink-dark mt-3">
        {t('galeria.subtitle')}
      </h2>
    </div>

    <!-- Gallery grid placeholder -->
    <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {[1, 2, 3, 4, 5, 6, 7, 8].map((i) => (
        <div
          data-gallery-item
          class:list={[
            'relative aspect-square rounded-xl overflow-hidden bg-gradient-to-br from-complementary-100 to-complementary-200 border border-complementary-200/50',
            i === 1 && 'md:row-span-2 md:col-span-2',
            i === 5 && 'md:col-span-2',
          ]}
        >
          <div class="absolute inset-0 flex items-center justify-center text-complementary-300/80">
            <svg viewBox="0 0 100 100" class="w-16 h-16 md:w-20 md:h-20">
              <circle cx="50" cy="45" r="15" fill="none" stroke="currentColor" stroke-width="1.5" />
              <path d="M20 75 L40 55 L55 70 L70 50 L85 75" fill="none" stroke="currentColor" stroke-width="1.5" />
              <rect x="15" y="15" width="70" height="70" rx="4" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3" />
            </svg>
          </div>
          <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <span class="text-white text-sm font-medium">Obra {i}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href={localePrefix === '' ? '/galeria' : `${localePrefix}/galeria`}
        class="inline-flex items-center px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700 transition-all duration-300"
      >
        {t('galeria.ver_mas')}
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════ -->
<!-- CTA / CONTACTO STRIP                                  -->
<!-- ════════════════════════════════════════════════════════ -->
<section class="py-24 px-4 bg-ink-dark text-white">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-display text-3xl sm:text-4xl font-bold mb-6">
      {t('contacto.title')}
    </h2>
    <p class="text-lg text-paper/70 mb-8 max-w-xl mx-auto">
      {t('contacto.subtitle')}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={localePrefix === '' ? '/contacto' : `${localePrefix}/contacto`}
        class="inline-flex items-center px-6 py-3 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700 transition-all duration-300 shadow-lg shadow-brand-600/25 hover:shadow-brand-600/40"
      >
        {t('contacto.form.enviar')}
      </a>
      <a
        href="https://wa.me/123456789"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 border-2 border-white/20 text-white/90 font-medium rounded-lg hover:border-white/40 hover:bg-white/5 transition-all duration-300"
      >
        {t('contacto.info.whatsapp')}
      </a>
    </div>
  </div>
</section>

<!-- GSAP Animations Script -->
<script>
  import { animateHero, animateFloatingShapes, animateGalleryGrid, animateReveal, cleanup } from '../scripts/animations.js';

  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('hero');
    if (hero) {
      animateHero(hero);
      animateFloatingShapes(hero);
    }

    const gallery = document.getElementById('gallery-grid');
    if (gallery) {
      animateGalleryGrid(gallery);
    }

    // Reveal service cards
    const cards = document.querySelectorAll('.group');
    animateReveal(cards);
  });

  // Cleanup on page navigation (if using view transitions)
  document.addEventListener('astro:before-swap', cleanup);
</script>
