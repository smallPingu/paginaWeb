---
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale || 'es';
const { t } = useTranslations(locale);
const localePrefix = locale === 'es' ? '' : `/${locale}`;

// Load blog posts via import.meta.glob
const rawModules = import.meta.glob('../content/blog/*.md', { eager: true });
const posts = Object.entries(rawModules)
  .map(([filepath, mod]: [string, any]) => ({
    slug: filepath.split('/').pop()?.replace(/\.md$/, ''),
    ...mod.frontmatter,
  }))
  .filter((p) => p.locale === locale && !p.draft)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<section class="py-24 px-4 min-h-screen">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-brand-600 text-sm font-medium uppercase tracking-widest">
        {t('blog.title')}
      </span>
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-ink-dark mt-3">
        {t('blog.subtitle')}
      </h1>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-8">
        {posts.map((post) => (
          <article class="bg-white rounded-2xl p-6 sm:p-8 border border-brand-100/50 hover:border-brand-300/50 hover:shadow-lg transition-all duration-300">
            <time class="text-sm text-brand-600 font-medium">
              {new Intl.DateTimeFormat(locale === 'uk' ? 'uk-UA' : locale === 'en' ? 'en-US' : 'es-AR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              }).format(new Date(post.date))}
            </time>
            <h2 class="font-display text-xl sm:text-2xl font-semibold text-ink-dark mt-2 mb-3">
              <a
                href={`${localePrefix}/blog/${post.slug}`}
                class="hover:text-brand-700 transition-colors"
              >
                {post.title}
              </a>
            </h2>
            <p class="text-ink-light leading-relaxed">{post.description}</p>
            <a
              href={`${localePrefix}/blog/${post.slug}`}
              class="inline-flex items-center mt-4 text-brand-600 font-medium text-sm hover:text-brand-700 transition-colors"
            >
              {t('blog.leer_mas')}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-brand-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <p class="text-ink-light text-lg">{t('blog.sin_articulos')}</p>
      </div>
    )}
  </div>
</section>

<script>
  import { animateReveal, cleanup } from '../scripts/animations.js';

  document.addEventListener('DOMContentLoaded', () => {
    const articles = document.querySelectorAll('article');
    animateReveal(articles, { stagger: 0.1 });
  });

  document.addEventListener('astro:before-swap', cleanup);
</script>
